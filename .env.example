# SmartCup Prediction Agent Template environment
#
# Copy to `.env` for local use. Do not put private keys, mnemonics, wallet JSON,
# or SubWallet export data in this file.

# Agent identity
SMARTPREDICTOR_HANDLE=your_agent_handle
SMARTPREDICTOR_NAME=your_agent_name
SMARTPREDICTOR_PUBLIC_BOT_NAME=your_bot_display_name

# Reusable setup guard
# This template ships with placeholder identity values. Personal deployments
# must replace the wallet, Telegram admin id, and bot name before production use.
# Keep SMARTPREDICTOR_ALLOW_DEFAULT_IDENTITY=false unless you are deliberately
# running a local documentation/demo smoke with placeholder identity values.
SMARTPREDICTOR_REUSABLE_SETUP_GUARD=true
SMARTPREDICTOR_ALLOW_DEFAULT_IDENTITY=false

# Local vara-wallet account nickname. This is not a private key.
SMARTPREDICTOR_WALLET_ACCOUNT=local_vara_wallet_name
SMARTPREDICTOR_WALLET_HEX=0xREPLACE_WITH_PUBLIC_WALLET
SMARTPREDICTOR_WALLET_SS58=ss58_replace_with_public_wallet

# Vara network
VARA_NETWORK=mainnet
VARA_RPC_URL=wss://rpc.vara.network
# Optional explicit binary path for a pinned/repaired local vara-wallet install.
# When unset, read commands use `npm exec --package=vara-wallet` for compatibility.
VARA_WALLET_BIN=/usr/local/bin/vara-wallet

# SmartCup World Cup MVP programs
SMARTCUP_BOLAO_CORE_ID=0x52f5f89954bbf1528f84eb1ca90100b47a6a50b0fe76e6ce31ed3ff55497ed98
SMARTCUP_ORACLE_ID=0xff7795305eaa4abe36cae9aa6b11373327eda01218c787cb391b7c38bc3fcfbb
# Optional until the Freebet Ledger deployment is confirmed.
SMARTCUP_FREEBET_LEDGER_ID=

# SmartCup read services
SMARTCUP_API_URL=https://smartcupleague-api.onrender.com
SMARTCUP_INDEXER_GRAPHQL_URL=http://localhost:4350/graphql
# Render/free hosted GraphQL can cold-start; keep this higher than normal API reads.
SMARTCUP_INDEXER_GRAPHQL_TIMEOUT_MS=60000
SMARTCUP_FIXTURE_PROVIDER=football-data.org
SMARTCUP_ODDS_PROVIDER=manual
SMARTCUP_FOOTBALL_CONTEXT_PROVIDER=manual
FOOTBALL_DATA_BASE_URL=https://api.football-data.org/v4
# Required only for football-data.org ingestion. Keep this local; do not commit real tokens.
FOOTBALL_DATA_API_TOKEN=
# Optional MVP odds snapshots for market comparison. Keep as JSON and local only.
# Example:
# SMARTCUP_ODDS_MANUAL_JSON=[{"provider":"manual","providerEventId":"match-4","matchId":"4","market":"match_winner","observedAt":"2026-06-04T00:00:00.000Z","sourceUrl":null,"confidence":0.6,"selections":[{"label":"United States","outcome":"home","priceDecimal":1.95,"impliedProbability":null,"line":null,"score":null,"team":"United States","bookmaker":"manual"},{"label":"Draw","outcome":"draw","priceDecimal":3.4,"impliedProbability":null,"line":null,"score":null,"team":null,"bookmaker":"manual"},{"label":"Paraguay","outcome":"away","priceDecimal":4.2,"impliedProbability":null,"line":null,"score":null,"team":"Paraguay","bookmaker":"manual"}]}]
SMARTCUP_ODDS_MANUAL_JSON=
# Optional MVP lineup, injury, suspension, and news context. Keep as JSON and local only.
# Example:
# SMARTCUP_FOOTBALL_CONTEXT_MANUAL_JSON={"lineups":[{"provider":"manual","matchId":"4","team":"United States","status":"projected","formation":"4-3-3","updatedAt":"2026-06-04T00:00:00.000Z","confidence":0.45,"players":[]}],"availability":[{"provider":"manual","team":"Paraguay","player":"Example Player","status":"doubtful","reason":"training knock","severity":"medium","updatedAt":"2026-06-04T00:00:00.000Z","confidence":0.5}],"news":[{"provider":"manual","itemId":"manual-news-1","title":"Example team-news note","publishedAt":"2026-06-04T00:00:00.000Z","teams":["United States"],"players":[],"tags":["lineup"],"impactDirection":"unknown","confidence":0.5,"sourceReliability":0.5}]}
SMARTCUP_FOOTBALL_CONTEXT_MANUAL_JSON=
# Current World Cup MVP BolaoCore deployment IDL.
# Do not point this at the freebet-v4 snapshot unless the BolaoCore program ID
# has also been upgraded to that contract version; otherwise QueryBetsByUser
# decodes with shifted fields.
SMARTCUP_BOLAO_IDL_PATH=artifacts/idl/bolao_program.idl
# Preserved future/upgraded BolaoCore artifact:
# SMARTCUP_BOLAO_IDL_PATH=artifacts/idl/bolao_program.freebet-v4.idl
# Only for deliberate protocol-migration smoke tests; never needed for normal MVP operation.
SMARTCUP_ALLOW_BOLAO_IDL_COMPATIBILITY_OVERRIDE=false
SMARTCUP_FREEBET_LEDGER_IDL_PATH=artifacts/idl/freebet-ledger.idl
SMARTCUP_ORACLE_IDL_PATH=artifacts/idl/oracle_program.idl
SMARTCUP_TOURNAMENT_PROFILE_PATH=tournaments/worldcup-2026.mvp.json
SMARTPREDICTOR_SQLITE_PATH=data/smartcup-agent.memory.sqlite
# Render hosted bot note:
# Attach a Render persistent disk mounted at /var/data, then set:
# SMARTPREDICTOR_SQLITE_PATH=/var/data/smartcup-agent.memory.sqlite
# Without persistent storage, saved DecisionReports can disappear after worker
# restarts or redeploys, which breaks Saved Decisions and Export Report.

# World Cup MVP economics, basis points
SMARTCUP_MATCH_WINNER_POOL_BPS=8500
SMARTCUP_FINAL_PRIZE_POOL_BPS=1000
SMARTCUP_PROTOCOL_FEE_BPS=500

# Agent execution policy
# Allowed values: read_only, approval_required, tournament_autopilot, claim_only
# This is the startup fallback. Telegram /operator_policy changes are also
# persisted in local memory/SQLite as the durable runtime policy.
SMARTPREDICTOR_POLICY_MODE=read_only

# Refuse predictions too close to the SmartCup 10-minute cutoff.
SMARTPREDICTOR_CUTOFF_BUFFER_MS=900000

# Mainnet safety defaults. Keep these at zero until you deliberately enable
# approval_required or tournament_autopilot execution.
SMARTPREDICTOR_MIN_STAKE_USD=3
SMARTPREDICTOR_MAX_STAKE_PLANCK=0
SMARTPREDICTOR_MAX_TOURNAMENT_EXPOSURE_PLANCK=0
# Optional USD-denominated caps. When set, these override the matching planck
# caps above and are converted through the SmartCup Oracle/BolaoCore VARA/USD
# protocol price before execution guards run.
SMARTPREDICTOR_MAX_STAKE_USD=
SMARTPREDICTOR_MAX_TOURNAMENT_EXPOSURE_USD=

# Production autopilot remains blocked unless all three are deliberately set
# after approval-required execution and live smoke verification are complete.
SMARTPREDICTOR_APPROVAL_FLOW_VERIFIED=false
SMARTPREDICTOR_LIVE_SMOKE_VERIFIED=false
SMARTPREDICTOR_LIVE_SMOKE_REFERENCE=

# Telegram UX MVP
# Create the bot with Telegram BotFather and keep the real token local.
TELEGRAM_BOT_TOKEN=
# Comma-separated numeric Telegram user ids allowed to run admin commands.
TELEGRAM_ADMIN_IDS=
# Allowed values: polling, webhook
TELEGRAM_MODE=polling
# Required only in webhook mode.
TELEGRAM_WEBHOOK_URL=
# Local webhook server bind settings. Public deployments usually bind 0.0.0.0.
TELEGRAM_WEBHOOK_HOST=0.0.0.0
TELEGRAM_WEBHOOK_PORT=8787
# Optional Telegram secret token checked against X-Telegram-Bot-Api-Secret-Token.
TELEGRAM_WEBHOOK_SECRET=
# Prediction-window reminders. By default, alerts are enabled, use TELEGRAM_ADMIN_IDS,
# and fire once per eligible match about 30 minutes before SmartCup prediction close.
# SmartCup prediction close is normally 10 minutes before kickoff, so the default
# reminder arrives about 40 minutes before kickoff.
TELEGRAM_PREDICTION_ALERTS_ENABLED=true
TELEGRAM_PREDICTION_ALERT_LEAD_MINUTES=30
TELEGRAM_PREDICTION_ALERT_SCAN_MS=300000
# Optional override. When empty, alerts go to TELEGRAM_ADMIN_IDS.
TELEGRAM_PREDICTION_ALERT_CHAT_IDS=
